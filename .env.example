# Pipeline behavior
APIM_MODE=auto
APIM_ENV=am47
WSO2_APIM_URL=https://wso2-apim:9443
APIM_USERNAME=admin
APIM_PASSWORD=admin
APIM_INSECURE_TLS=true

# Public URLs used by the demo browser
TELCO_BACKEND_PUBLIC_URL=http://localhost:8081
PIPELINE_PUBLIC_URL=http://localhost:8090

# BEGIN TELCO LIVE MOESIF ANALYTICS
# Enable only when a valid Moesif Collector Application ID is available.
TELCO_ENABLE_MOESIF_ANALYTICS=false
MOESIF_APPLICATION_ID=
MOESIF_BASE_URL=https://api.moesif.net
TELCO_GATEWAY_NAME=regional-telco-gateway
TELCO_GATEWAY_REGION=south-america-east
TELCO_GATEWAY_COUNTRY=BR

# Verification-only Management API credentials. Never commit real values.
MOESIF_MANAGEMENT_TOKEN=
MOESIF_ORG_ID=~
# END TELCO LIVE MOESIF ANALYTICS

