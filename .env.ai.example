# Copy this file to .env.ai.local. The local file is git-ignored.
OPENAI_API_KEY=replace-me
AI_LLM_BASE_URL=https://api.openai.com/v1
AI_MODEL_STANDARD=gpt-4o-mini
AI_MODEL_ADVANCED=gpt-4o
AI_MAX_OUTPUT_TOKENS_STANDARD=700
AI_MAX_OUTPUT_TOKENS_ADVANCED=1200
AI_TOOL_TIMEOUT_SECONDS=12
AI_MAX_HISTORY=6
AI_PARTNER_DAILY_TOKEN_QUOTA=100000
AI_STANDARD_INPUT_USD_PER_1M=0.15
AI_STANDARD_OUTPUT_USD_PER_1M=0.60
AI_ADVANCED_INPUT_USD_PER_1M=2.50
AI_ADVANCED_OUTPUT_USD_PER_1M=10.00
AI_APIM_REQUEST_POLICY=TelcoAIRequests
AI_APIM_TOKEN_POLICY=TelcoAITokenQuota
