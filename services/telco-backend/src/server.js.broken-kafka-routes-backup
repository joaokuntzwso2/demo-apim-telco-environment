const express = require('express');
const {
  kafkaTopics,
  kafkaStatus,
  publishKafkaEvent,
  recentKafkaEvents
} = require('./kafka-broker');


 

app.get('/api/v1/kafka/status', async (req, res) => {
  res.json(await kafkaStatus());
});

app.get('/api/v1/kafka/topics', async (req, res) => {
  res.json({
    topics: kafkaTopics,
    story: 'Real Kafka-protocol topics used by the event-native telco monetization demo.'
  });
});

app.get('/api/v1/kafka/topics/:topic/events', async (req, res) => {
  const topic = req.params.topic;

  if (!kafkaTopics.includes(topic)) {
    return res.status(404).json({
      error: 'topic_not_found',
      topic,
      availableTopics: kafkaTopics
    });
  }

  res.json(await recentKafkaEvents(topic));
});

app.post('/api/v1/kafka/topics/:topic/events', async (req, res) => {
  const topic = req.params.topic;

  if (!kafkaTopics.includes(topic)) {
    return res.status(404).json({
      error: 'topic_not_found',
      topic,
      availableTopics: kafkaTopics
    });
  }

  const event = Object.assign({
    eventId: `evt-${Date.now()}`,
    eventType: 'BROKER_EVENT',
    topic,
    partnerId: 'demo-partner',
    country: 'BR',
    payload: {
      message: 'Demo Kafka event'
    },
    commercial: {
      billable: true,
      meter: 'broker_event_delivery',
      productKey: 'moesif_prod_event_native_broker_simulation',
      billingCatalogReference: 'billing.catalog.event-native-broker-simulation.v1',
      revenueShareModel: 'EVENT_STREAM_REVENUE_SHARE',
      settlementOwner: 'Telco Network Monetization Office'
    }
  }, req.body || {});

  const result = await publishKafkaEvent(topic, event);
  res.status(result.delivered ? 201 : 202).json(result);
});

