<?xml version="1.0" encoding="UTF-8"?>
<sequence name="SubscriberAuthorizationDenySequence" trace="disable" xmlns="http://ws.apache.org/ns/synapse">
    <property name="HTTP_SC" expression="get-property('auth.error.status')" scope="axis2" type="INTEGER"/>
    <property name="messageType" scope="axis2" type="STRING" value="application/json"/>
    <property name="ContentType" scope="axis2" type="STRING" value="application/json"/>
    <header name="X-Correlation-ID" expression="get-property('correlation.id')" scope="transport"/>
    <payloadFactory media-type="json">
        <format>{
          "code":"$1",
          "message":"$2",
          "correlationId":"$3",
          "details":{
            "persona":"$4",
            "authenticatedPartnerId":"$5",
            "requestedPartnerId":"$6",
            "country":"$7",
            "purpose":"$8"
          }
        }</format>
        <args>
            <arg evaluator="xml" expression="get-property('auth.error.code')"/>
            <arg evaluator="xml" expression="get-property('auth.error.message')"/>
            <arg evaluator="xml" expression="get-property('correlation.id')"/>
            <arg evaluator="xml" expression="get-property('persona')"/>
            <arg evaluator="xml" expression="get-property('authorized.partner.id')"/>
            <arg evaluator="xml" expression="get-property('requested.partner.id')"/>
            <arg evaluator="xml" expression="get-property('requested.country')"/>
            <arg evaluator="xml" expression="get-property('requested.purpose')"/>
        </args>
    </payloadFactory>
    <respond/>
</sequence>
