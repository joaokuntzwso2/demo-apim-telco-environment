<?xml version="1.0" encoding="UTF-8"?>
<sequence xmlns="http://ws.apache.org/ns/synapse" name="BillingModernizationTransportFaultSequence">
    <switch source="get-property('ERROR_CODE')">
        <case regex="101504|101505">
            <property name="normalizedErrorCode" value="LEGACY_BILLING_TIMEOUT" scope="default" type="STRING"/>
            <property name="normalizedErrorTitle" value="Legacy billing timeout" scope="default" type="STRING"/>
            <property name="normalizedHttpStatus" value="504" scope="default" type="STRING"/>
            <property name="HTTP_SC" value="504" scope="axis2" type="STRING"/>
        </case>
        <default>
            <property name="normalizedErrorCode" value="LEGACY_BILLING_UNAVAILABLE" scope="default" type="STRING"/>
            <property name="normalizedErrorTitle" value="Legacy billing unavailable" scope="default" type="STRING"/>
            <property name="normalizedHttpStatus" value="503" scope="default" type="STRING"/>
            <property name="HTTP_SC" value="503" scope="axis2" type="STRING"/>
        </default>
    </switch>

    <log category="ERROR" level="custom">
        <property name="event" value="legacy-billing-transport-fault"/>
        <property name="correlationId" expression="get-property('correlation.id')"/>
        <property name="errorCode" expression="get-property('ERROR_CODE')"/>
        <property name="errorMessage" expression="get-property('ERROR_MESSAGE')"/>
        <property name="errorDetail" expression="get-property('ERROR_DETAIL')"/>
    </log>

    <script language="js"><![CDATA[
        function value(name, fallback) {
            var current = mc.getProperty(name);
            return current == null || String(current).length === 0 ? fallback : String(current);
        }
        var status = Number(mc.getProperty('normalizedHttpStatus') || 503);
        mc.setPayloadJSON({
            type: 'https://demo.americamovil.com/errors/' + value('normalizedErrorCode', 'LEGACY_BILLING_UNAVAILABLE').toLowerCase().replace(/_/g, '-'),
            title: value('normalizedErrorTitle', 'Legacy billing unavailable'),
            status: status,
            code: value('normalizedErrorCode', 'LEGACY_BILLING_UNAVAILABLE'),
            detail: value('ERROR_MESSAGE', 'No legacy billing node was available'),
            integrationErrorCode: value('ERROR_CODE', 'MI-TRANSPORT-ERROR'),
            correlationId: value('correlation.id', '')
        });
    ]]></script>
    <property name="messageType" value="application/problem+json" scope="axis2" type="STRING"/>
    <property name="ContentType" value="application/problem+json" scope="axis2" type="STRING"/>
    <property name="X-Correlation-ID" expression="get-property('correlation.id')" scope="transport" type="STRING"/>
    <respond/>
</sequence>
