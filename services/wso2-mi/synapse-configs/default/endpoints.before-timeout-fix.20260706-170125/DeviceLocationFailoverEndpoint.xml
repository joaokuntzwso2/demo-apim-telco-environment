<?xml version="1.0" encoding="UTF-8"?>
<endpoint xmlns="http://ws.apache.org/ns/synapse" name="DeviceLocationFailoverEndpoint">
    <failover>
        <endpoint name="DeviceLocationFailoverEndpointAttempt1">
            <http method="post" uri-template="${configs.device_location_base_url}/location/verify">
                <timeout>
                    <duration>${configs.backend_timeout_ms}</duration>
                    <responseAction>fault</responseAction>
                </timeout>
                <suspendOnFailure>
                    <errorCodes>101500,101501,101503,101506,101507,101508,101509,101510</errorCodes>
                    <initialDuration>${configs.backend_suspend_initial_ms}</initialDuration>
                    <progressionFactor>2.0</progressionFactor>
                    <maximumDuration>${configs.backend_suspend_max_ms}</maximumDuration>
                </suspendOnFailure>
                <markForSuspension>
                    <errorCodes>101504,101505</errorCodes>
                    <retriesBeforeSuspension>0</retriesBeforeSuspension>
                    <retryDelay>0</retryDelay>
                </markForSuspension>
            </http>
        </endpoint>
        <endpoint name="DeviceLocationFailoverEndpointAttempt2">
            <http method="post" uri-template="${configs.device_location_base_url}/location/verify">
                <timeout>
                    <duration>${configs.backend_timeout_ms}</duration>
                    <responseAction>fault</responseAction>
                </timeout>
                <suspendOnFailure>
                    <errorCodes>101500,101501,101503,101506,101507,101508,101509,101510</errorCodes>
                    <initialDuration>${configs.backend_suspend_initial_ms}</initialDuration>
                    <progressionFactor>2.0</progressionFactor>
                    <maximumDuration>${configs.backend_suspend_max_ms}</maximumDuration>
                </suspendOnFailure>
                <markForSuspension>
                    <errorCodes>101504,101505</errorCodes>
                    <retriesBeforeSuspension>0</retriesBeforeSuspension>
                    <retryDelay>0</retryDelay>
                </markForSuspension>
                <retryConfig>
                    <disabledErrorCodes>101500,101501,101503,101504,101505,101506,101507,101508,101509,101510</disabledErrorCodes>
                </retryConfig>
            </http>
        </endpoint>
    </failover>
</endpoint>
