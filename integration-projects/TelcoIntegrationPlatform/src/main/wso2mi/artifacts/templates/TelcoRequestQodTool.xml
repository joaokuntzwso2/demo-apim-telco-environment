<?xml version="1.0" encoding="UTF-8"?>
<template name="TelcoRequestQodTool" xmlns="http://ws.apache.org/ns/synapse">
  <parameter name="subscriberId" description="Subscriber identifier" isMandatory="true"/>
  <parameter name="durationSeconds" description="Duration 60 to 3600 seconds" isMandatory="true"/>
  <parameter name="profile" description="LOW_LATENCY or HIGH_THROUGHPUT" isMandatory="false"/>
  <sequence>
    <payloadFactory media-type="json"><format>{"subscriberId":"$1","durationSeconds":$2,"profile":"$3"}</format><args>
      <arg evaluator="xml" expression="$func:subscriberId"/><arg evaluator="xml" expression="$func:durationSeconds"/><arg evaluator="xml" expression="$func:profile"/>
    </args></payloadFactory>
    <header name="Authorization" expression="fn:concat('Bearer ', get-property('transport','X-Agent-Tool-Token'))" scope="transport"/>
    <header name="X-Correlation-ID" expression="get-property('correlationId')" scope="transport"/>
    <header name="X-Partner-Id" expression="get-property('partnerId')" scope="transport"/>
    <header name="Idempotency-Key" expression="fn:concat('agent-qod-', get-property('correlationId'))" scope="transport"/>
    <call><endpoint><http method="POST" uri-template="http://wso2-apim:8280/telco-agent-tools/v1/qod-sessions">
      <timeout><duration>7000</duration><responseAction>fault</responseAction></timeout>
      <suspendOnFailure><initialDuration>5000</initialDuration><progressionFactor>2.0</progressionFactor><maximumDuration>30000</maximumDuration></suspendOnFailure>
      <markForSuspension><retriesBeforeSuspension>0</retriesBeforeSuspension><retryDelay>0</retryDelay></markForSuspension>
    </http></endpoint></call>
  </sequence>
</template>
