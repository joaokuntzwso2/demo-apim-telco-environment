    <resource methods="GET" uri-template="/partners/{partnerId}/commercial-usage">
        <inSequence>
            <property name="capability" scope="default" type="STRING" value="commercial-usage"/>
            <sequence key="SubscriberAuthorizationContextSequence"/>
            <property name="requested.partner.id" expression="get-property('uri.var.partnerId')" scope="default" type="STRING"/>
            <property name="requested.country" expression="$url:country" scope="default" type="STRING"/>
            <filter xpath="not(normalize-space(get-property('requested.country')))">
                <then><property name="requested.country" scope="default" type="STRING" value="BR"/></then>
            </filter>
            <property name="requested.purpose" scope="default" type="STRING" value="commercial-reporting"/>
            <property name="requested.consent.id" scope="default" type="STRING" value="NOT_REQUIRED"/>
            <sequence key="SubscriberAuthorizationBusinessControlSequence"/>
            <property name="uri.var.partnerId" expression="get-property('requested.partner.id')" scope="default" type="STRING"/>
            <property name="HTTP_METHOD" scope="axis2" type="STRING" value="GET"/>
            <call><endpoint key="SubscriberCommercialUsageFailoverEndpoint"/></call>
            <payloadFactory media-type="json">
                <format>{
                  "decision":"ALLOW",
                  "capability":"commercial-usage",
                  "persona":"$1",
                  "partnerId":"$2",
                  "country":"$3",
                  "consent":{"id":"NOT_REQUIRED","purpose":"commercial-reporting","status":"NOT_REQUIRED"},
                  "commercial":{"source":"SecureMobileTransactionsCommercialAPI","planVisibility":"AUTHORIZED_PARTNER_ONLY"},
                  "correlationId":"$4"
                }</format>
                <args>
                    <arg evaluator="xml" expression="get-property('persona')"/>
                    <arg evaluator="xml" expression="get-property('requested.partner.id')"/>
                    <arg evaluator="xml" expression="get-property('requested.country')"/>
                    <arg evaluator="xml" expression="get-property('correlation.id')"/>
                </args>
            </payloadFactory>
            <header name="X-Correlation-ID" expression="get-property('correlation.id')" scope="transport"/>
            <property name="HTTP_SC" scope="axis2" type="INTEGER" value="200"/>
            <respond/>
        </inSequence>
        <faultSequence><sequence key="SubscriberAuthorizationFaultSequence"/></faultSequence>
    </resource>
</api>
